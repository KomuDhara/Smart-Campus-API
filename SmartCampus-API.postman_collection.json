{
  "info": {
    "name": "SmartCampus API",
    "description": "REST API for managing campus rooms and IoT sensors \u2014 built with JAX-RS (Jersey 2.x) on Apache Tomcat 9.\n\n\u26a0\ufe0f Data is stored IN-MEMORY \u2014 resets on every Tomcat restart.\n\n\u2705 Always follow this order:\n1. POST room\n2. POST sensor\n3. POST reading",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "smartcampus-api-v1"
  },
  "item": [
    {
      "name": "DISCOVERY",
      "item": [
        {
          "name": "GET Discovery",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/Smart-Campus-API/api/v1/",
              "host": [
                "localhost"
              ],
              "path": [
                "Smart-Campus-API",
                "api",
                "v1",
                ""
              ],
              "protocol": "http",
              "port": "8080"
            },
            "description": "Returns API metadata and available resource links (HATEOAS).\nExpected: 200 OK"
          },
          "response": []
        }
      ]
    },
    {
      "name": "ROOMS",
      "item": [
        {
          "name": "POST Create Room",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"R1\",\n  \"name\": \"Lecture Hall A\",\n  \"capacity\": 100\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:8080/Smart-Campus-API/api/v1/rooms",
              "host": [
                "localhost"
              ],
              "path": [
                "Smart-Campus-API",
                "api",
                "v1",
                "rooms"
              ],
              "protocol": "http",
              "port": "8080"
            },
            "description": "Create a new room. ID must be unique.\nExpected: 201 Created"
          },
          "response": []
        },
        {
          "name": "GET All Rooms",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/Smart-Campus-API/api/v1/rooms",
