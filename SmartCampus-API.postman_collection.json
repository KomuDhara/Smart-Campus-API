                "api",
                "v1",
                "rooms",
                "R1"
              ],
              "protocol": "http",
              "port": "8080"
            },
            "description": "Update room name and/or capacity.\nExpected: 200 OK"
          },
          "response": []
        },
        {
          "name": "DELETE Room (no sensors) \u2705",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/Smart-Campus-API/api/v1/rooms/R1",
              "host": [
                "localhost"
              ],
              "path": [
                "Smart-Campus-API",
                "api",
                "v1",
                "rooms",
                "R1"
              ],
              "protocol": "http",
              "port": "8080"
            },
            "description": "Delete a room. Only works if no sensors are assigned.\nExpected: 204 No Content"
          },
          "response": []
