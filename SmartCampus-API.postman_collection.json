        {
          "name": "DELETE Room with Sensors \u274c (409)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/Smart-Campus-API/api/v1/rooms/R1",
              "host": [
                "localhost"
              ],
              "path": [
                "Smart-Campus-API",
                "api",
                "v1",
                "rooms",
                "R1"
              ],
              "protocol": "http",
              "port": "8080"
            },
            "description": "Attempt to delete a room that still has sensors assigned.\nExpected: 409 Conflict"
          },
          "response": []
        }
      ]
